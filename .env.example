# Postgres connection string.
# - Local via `npm run dev` against the docker-compose db: postgresql://lanna:lanna@localhost:5432/lanna_lyrics
# - Inside docker-compose (app container talking to the db container): postgresql://lanna:lanna@db:5432/lanna_lyrics
# - Production (Vercel): set this to your managed Postgres (Neon / Vercel Postgres / Supabase) connection string.
DATABASE_URL="postgresql://lanna:lanna@localhost:5432/lanna_lyrics"

# Shared password for the teacher/admin login (single-admin, kept simple on purpose).
ADMIN_PASSWORD="changeme"

# Random long string used to sign the admin session cookie. Generate with:
#   openssl rand -base64 32
ADMIN_SESSION_SECRET="change-this-to-a-random-32-byte-secret"
